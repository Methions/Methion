local function slideIn()
TweenService:Create(card, TweenInfo.new(0.6, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Position = UDim2.new(1,-20-WIDTH,0,20)}):Play()
end

local function slideOutAndRemove()
local tween = TweenService:Create(card, TweenInfo.new(0.45, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {Position = UDim2.new(1,-20-WIDTH,0,-HEIGHT-20)})
tween:Play()
tween.Completed:Connect(function() screenGui:Destroy() end)
end

